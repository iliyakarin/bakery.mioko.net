---
import Layout from '../layouts/Layout.astro';

const cookies = [
  {
    name: "Dark Chocolate Brookie",
    description: "Brownie meets cookie — fudgy dark chocolate centre, crisp edge, barely sweet.",
    image: "/images/cookie-brooky-withe-dark-choco.jpg",
  },
  {
    name: "Lemon & Cashew",
    description: "Bright citrus zest against the buttery richness of roasted cashews.",
    image: "/images/cookie-lemon-cashew.jpg",
  },
  {
    name: "Chocolate Nutella",
    description: "NY-style thick cookie with a molten Nutella centre and a deep cocoa crumb.",
    image: "/images/cookie-ny-choco-nutella.jpg",
  },
  {
    name: "Lotus Biscoff",
    description: "Swirls of Biscoff cookie butter through a soft, golden dough.",
    image: "/images/cookie-ny-lotus-biscoff.jpg",
  },
  {
    name: "Oreo & White Chocolate",
    description: "Crushed Oreo folded into a creamy white chocolate dough.",
    image: "/images/cookie-ny-oreo-white-choco.jpg",
  },
  {
    name: "Peanut Butter",
    description: "Classic NY-style — thick, fudgy, intensely nutty. Natural peanut butter, no shortcuts.",
    image: "/images/cookie-ny-peanut-butter.jpg",
  },
  {
    name: "Oats, Cranberry & Cinnamon",
    description: "Wholesome rolled oats with tart dried cranberries and warm cinnamon.",
    image: "/images/cookie-oats-cranberry-cinnamon.jpg",
  },
  {
    name: "Seasonal Assorted Box",
    description: "A curated selection of the week's flavours — perfect for sharing or gifting.",
    image: "/images/cookie-ny-assortie-box.jpg",
  },
  {
    name: "Party Size Box",
    description: "A large-format box for gatherings, events, or anyone who refuses to choose just one.",
    image: "/images/cookie-party-size-box.jpg",
  },
];

const faqs = [
  {
    q: "Are all ingredients organic?",
    a: "Yes. I use certified organic flour, butter, eggs, and sweeteners. Specialty add-ins like chocolate and nuts are sustainably sourced from small producers.",
  },
  {
    q: "How do I place an order?",
    a: "Message me on Instagram or send an email. I'll confirm flavor availability, batch size, and arrange a pickup time.",
  },
  {
    q: "How far in advance should I order?",
    a: "3–5 days for standard orders. For holidays or custom boxes, please reach out 1–2 weeks ahead. I bake in small, intentional batches.",
  },
  {
    q: "Where is pickup?",
    a: "Round Rock, TX. I'll share the exact address once your order is confirmed.",
  },
  {
    q: "Can I request custom flavors or gift packaging?",
    a: "Absolutely. Custom seasonal flavors, curated gift boxes, and ribbon-wrapped tins are all available — just ask.",
  },
];

const philosophy = [
  { label: "Organic Ingredients", body: "Certified organic flour, butter, and eggs in every batch." },
  { label: "Less Sweet, More Flavor", body: "Sugar lifts the other flavors — it doesn't drown them." },
  { label: "Small Batch, Local", body: "Made in Round Rock, picked up in Round Rock." },
];

const steps = [
  {
    step: "01",
    title: "Browse the Collection",
    body: "Explore the cookie flavors here. Check Instagram for the latest batch and seasonal availability.",
  },
  {
    step: "02",
    title: "Send a Message",
    body: "DM on Instagram or email directly. Tell me which flavors and how many — I'll confirm and give you a pickup window.",
  },
  {
    step: "03",
    title: "Local Pickup, Round Rock",
    body: "Pick up your order fresh from my home bakery in Round Rock, TX. No delivery fees, no courier.",
  },
];
---

<Layout title="Mioko Bakery — Handcrafted Organic Cookies in Round Rock, TX">

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- NAV                                                             -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-cream-50/90 backdrop-blur-sm border-b border-cream-200">
    <div class="max-w-screen-xl mx-auto px-6">
      <nav class="flex items-center justify-between h-16">

        <a href="#" class="font-serif text-xl font-medium tracking-wide text-bark-900">
          Mioko
        </a>

        <ul class="hidden md:flex items-center gap-8">
          <li><a href="#cookies" class="text-xs tracking-widest uppercase text-bark-700 font-medium hover:text-bark-900 transition-colors">Cookies</a></li>
          <li><a href="#story"   class="text-xs tracking-widest uppercase text-bark-700 font-medium hover:text-bark-900 transition-colors">Our Story</a></li>
          <li><a href="#faq"     class="text-xs tracking-widest uppercase text-bark-700 font-medium hover:text-bark-900 transition-colors">FAQ</a></li>
          <li>
            <a href="#connect" class="inline-block px-5 py-2 border border-bark-800 text-bark-800 text-xs tracking-widest uppercase font-medium hover:bg-bark-800 hover:text-cream-50 transition-colors">
              Connect
            </a>
          </li>
        </ul>

      </nav>
    </div>
  </header>

  <main class="pt-16">

    <!-- ─────────────────────────────────────────────────────────────── -->
    <!-- HERO                                                            -->
    <!-- Image sits in its own block container with an explicit height.  -->
    <!-- Text lives below in normal document flow — no z-index stacking. -->
    <!-- ─────────────────────────────────────────────────────────────── -->
    <section>

      <!-- Image block -->
      <div class="relative h-[65vh] overflow-hidden">
        <img
          src="/images/hero.jpg"
          alt="Handcrafted organic cookies on a linen cloth"
          class="w-full h-full object-cover object-center"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-cream-50/70 pointer-events-none"></div>
      </div>

      <!-- Text block -->
      <div class="bg-cream-50 py-16">
        <div class="max-w-screen-xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          
          <div>
            <p class="text-xs tracking-widest uppercase text-earth-500 font-medium mb-5">Round Rock, Texas</p>

            <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-light leading-[1.1] text-bark-900 mb-6">
              Handcrafted,<br />
              <em class="not-italic">Organic</em> Cookies<br />
              in Round Rock.
            </h1>

            <p class="text-bark-700 text-lg font-light leading-relaxed max-w-xl mt-6 mb-10">
              Inspired by European pastry tradition — where sweetness serves the ingredient,
              not the other way around. Organic, small-batch, made with care in Round Rock.
            </p>

            <div class="flex flex-wrap gap-4">
              <a href="#cookies" class="inline-block px-8 py-3 bg-bark-800 text-cream-50 text-xs tracking-widest uppercase font-medium hover:bg-bark-900 transition-colors">
                Browse Cookies
              </a>
              <a href="#connect" class="inline-block px-8 py-3 border border-bark-800 text-bark-800 text-xs tracking-widest uppercase font-medium hover:bg-bark-800 hover:text-cream-50 transition-colors">
                How to Order
              </a>
            </div>
          </div>

          <div class="hidden md:flex justify-end">
            <img 
              src="/images/round-rock.png" 
              alt="Round Rock, Texas" 
              class="w-full max-w-md h-auto object-contain opacity-90 mix-blend-multiply" 
            />
          </div>

        </div>
      </div>

    </section>

    <!-- ─────────────────────────────────────────────────────────────── -->
    <!-- PHILOSOPHY STRIP                                                -->
    <!-- ─────────────────────────────────────────────────────────────── -->
    <section class="bg-cream-200 py-12">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          {philosophy.map((item) => (
            <div class="py-4">
              <p class="text-xs tracking-widest uppercase text-earth-500 font-medium mb-2">{item.label}</p>
              <p class="text-bark-700 font-light leading-relaxed text-sm">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─────────────────────────────────────────────────────────────── -->
    <!-- COOKIE GALLERY                                                  -->
    <!-- aspect-square + object-cover ensures a stable grid regardless  -->
    <!-- of source image dimensions.                                     -->
    <!-- ─────────────────────────────────────────────────────────────── -->
    <section id="cookies" class="py-24 bg-cream-50">
      <div class="max-w-screen-xl mx-auto px-6">

        <!-- Section header -->
        <div class="text-center mb-16">
          <p class="text-xs tracking-widest uppercase text-earth-500 font-medium mb-4">The Collection</p>
          <h2 class="font-serif text-4xl md:text-5xl font-light text-bark-900">Meet the Cookies</h2>
          <div class="mx-auto mt-5 w-12 h-px bg-earth-400"></div>
        </div>

        <!-- Grid: 2 columns on mobile, 3 on desktop -->
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          {cookies.map((cookie) => (
            <article class="group flex flex-col">
              <div class="aspect-square overflow-hidden bg-cream-200">
                <img
                  src={cookie.image}
                  alt={cookie.name}
                  class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="pt-4 flex flex-col flex-1">
                <h3 class="font-serif text-lg md:text-xl font-medium text-bark-900 mb-2">{cookie.name}</h3>
                <p class="text-bark-700 text-sm font-light leading-relaxed">{cookie.description}</p>
              </div>
            </article>
          ))}
        </div>

        <p class="text-center mt-14 text-bark-700 text-sm font-light">
          Seasonal flavors rotate throughout the year.
          <a href="#contact" class="text-earth-500 underline underline-offset-4 hover:text-earth-400 transition-colors ml-1">
            Ask about what's available this week.
          </a>
        </p>

      </div>
    </section>

    <!-- ─────────────────────────────────────────────────────────────── -->
    <!-- HOW IT WORKS                                                    -->
    <!-- ─────────────────────────────────────────────────────────────── -->
    <section class="py-24 bg-cream-100">
      <div class="max-w-screen-xl mx-auto px-6">

        <div class="text-center mb-16">
          <p class="text-xs tracking-widest uppercase text-earth-500 font-medium mb-4">Simple Process</p>
          <h2 class="font-serif text-4xl md:text-5xl font-light text-bark-900">How to Order</h2>
          <div class="mx-auto mt-5 w-12 h-px bg-earth-400"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          {steps.map((item) => (
            <div class="flex flex-col items-center text-center">
              <span class="font-serif text-5xl font-light text-earth-400 mb-5 leading-none">{item.step}</span>
              <h3 class="font-serif text-xl font-medium text-bark-900 mb-3">{item.title}</h3>
              <p class="text-bark-700 text-sm font-light leading-relaxed max-w-xs">{item.body}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ─────────────────────────────────────────────────────────────── -->
    <!-- THE STORY                                                       -->
    <!-- Two-column grid: image column left, text column right.         -->
    <!-- items-start prevents the image from stretching to match text.  -->
    <!-- ─────────────────────────────────────────────────────────────── -->
    <section id="story" class="py-24 bg-cream-50">
      <div class="max-w-screen-xl mx-auto px-6">

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

          <!-- Image -->
          <div class="w-full overflow-hidden bg-cream-200">
            <img
              src="/images/about.jpg"
              alt="Mioko baking in her kitchen"
              class="w-full h-auto block"
            />
          </div>

          <!-- Text -->
          <div class="flex flex-col justify-center">
            <p class="text-xs tracking-widest uppercase text-earth-500 font-medium mb-5">Our Story</p>
            <h2 class="font-serif text-4xl md:text-5xl font-light text-bark-900 leading-tight mb-8">
              A Russian Kitchen,<br />
              <em class="font-light">Now in Texas.</em>
            </h2>
            <div class="space-y-5 text-bark-700 font-light leading-relaxed">
              <p>
                I grew up watching my grandmother bake. Not measuring, not following recipes — just
                knowing. She believed good pastry should taste of its ingredients, not of sugar.
                A walnut cookie should taste like walnut. A honey shortbread should taste like honey.
              </p>
              <p>
                When my husband and I moved to Round Rock, I missed those flavors. I missed cookies
                that didn't leave you thirsty, that you could eat two of without feeling heavy.
                So I started baking them myself.
              </p>
              <p>
                I trained as a pastry chef in Russia, and I brought that education here — along with
                a belief that organic ingredients and restraint in sweetness make for a better cookie.
                I started sharing them with neighbors. Then neighbors started sharing them with friends.
              </p>
              <p class="font-normal text-bark-800">
                Now I bake for you. Small batches, organic ingredients, honest flavors — made with love
                for our community here in Round Rock.
              </p>
            </div>
            <div class="mt-10 pt-10 border-t border-cream-300">
              <p class="font-serif text-2xl font-light italic text-bark-800">— Mioko</p>
              <p class="text-xs tracking-widest uppercase text-earth-500 mt-1 font-medium">Pastry Chef & Baker</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ─────────────────────────────────────────────────────────────── -->
    <!-- FAQ                                                             -->
    <!-- ─────────────────────────────────────────────────────────────── -->
    <section id="faq" class="py-24 bg-cream-100">
      <div class="max-w-screen-xl mx-auto px-6">

        <div class="text-center mb-16">
          <p class="text-xs tracking-widest uppercase text-earth-500 font-medium mb-4">Questions</p>
          <h2 class="font-serif text-4xl md:text-5xl font-light text-bark-900">FAQ</h2>
          <div class="mx-auto mt-5 w-12 h-px bg-earth-400"></div>
        </div>

        <dl class="max-w-3xl mx-auto divide-y divide-cream-300">
          {faqs.map((faq) => (
            <div class="py-7">
              <dt class="font-serif text-xl font-medium text-bark-900 mb-3">{faq.q}</dt>
              <dd class="text-bark-700 font-light leading-relaxed text-sm">{faq.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- ─────────────────────────────────────────────────────────────── -->
    <!-- CONNECT / CONTACT SECTION                                       -->
    <!-- ─────────────────────────────────────────────────────────────── -->
    <section id="connect" class="py-24 bg-cream-50">
      <div class="max-w-screen-xl mx-auto px-6">
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          
          <div>
            <p class="text-xs tracking-widest uppercase text-earth-500 font-medium mb-4">Get in Touch</p>
            <h2 class="font-serif text-4xl md:text-5xl font-light text-bark-900 mb-8">Let's connect.</h2>
            
            <div class="space-y-8">
              <div>
                <h3 class="text-xs tracking-widest uppercase text-earth-400 font-medium mb-3">Email</h3>
                <a href="mailto:hello@bakery.mioko.net" class="font-serif text-2xl text-bark-800 hover:text-earth-500 transition-colors">
                  hello@bakery.mioko.net
                </a>
              </div>

              <div>
                <h3 class="text-xs tracking-widest uppercase text-earth-400 font-medium mb-3">Location</h3>
                <p class="font-serif text-2xl text-bark-800">
                  Round Rock, Texas
                </p>
                <p class="text-bark-600 text-sm font-light mt-1">Local pickup only — address shared upon confirmation.</p>
              </div>

              <div>
                <h3 class="text-xs tracking-widest uppercase text-earth-400 font-medium mb-3">Ordering</h3>
                <p class="text-bark-700 font-light leading-relaxed">
                  I bake in small, intentional batches. To place an order, message me on 
                  <strong>Instagram</strong> or <strong>Telegram</strong>, or send an <strong>email</strong>. 
                  Typically 3–5 days notice is required.
                </p>
              </div>
            </div>
          </div>

          <div class="bg-cream-100 p-10 md:p-16 rounded-sm border border-cream-200">
            <p class="text-center text-xs tracking-widest uppercase text-earth-500 font-medium mb-10">Scan to Follow & Order</p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-12">
              
              <!-- Instagram QR -->
              <div class="flex flex-col items-center group">
                <a 
                  href="https://www.instagram.com/mioko.bakery" 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="relative block aspect-square w-full max-w-[180px] bg-white p-4 shadow-sm group-hover:shadow-md transition-shadow duration-300"
                >
                  <img 
                    src="/images/mioko.bakery_qr-instagram.png" 
                    alt="Instagram QR Code" 
                    class="w-full h-full object-contain"
                  />
                  <div class="absolute inset-0 border border-bark-900/5 group-hover:border-earth-400/30 transition-colors"></div>
                </a>
                <p class="mt-4 font-serif text-lg text-bark-900 group-hover:text-earth-500 transition-colors">@mioko.bakery</p>
                <p class="text-[10px] tracking-widest uppercase text-bark-500 mt-1">Instagram</p>
              </div>

              <!-- Telegram QR -->
              <div class="flex flex-col items-center group">
                <a 
                  href="https://t.me/+gwn4uv3GRi03MThi" 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="relative block aspect-square w-full max-w-[180px] bg-white p-4 shadow-sm group-hover:shadow-md transition-shadow duration-300"
                >
                  <img 
                    src="/images/mioko.bakery_qr-telegram.jpg" 
                    alt="Telegram QR Code" 
                    class="w-full h-full object-contain"
                  />
                  <div class="absolute inset-0 border border-bark-900/5 group-hover:border-earth-400/30 transition-colors"></div>
                </a>
                <p class="mt-4 font-serif text-lg text-bark-900 group-hover:text-earth-500 transition-colors">Telegram Group</p>
                <p class="text-[10px] tracking-widest uppercase text-bark-500 mt-1">Community</p>
              </div>

            </div>
          </div>

        </div>

      </div>
    </section>

  </main>

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- FOOTER / CONTACT                                                -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <footer class="bg-bark-900 text-cream-100 py-20">
    <div class="max-w-screen-xl mx-auto px-6">

      <div class="flex flex-col md:flex-row justify-between items-start gap-12 mb-16">
        <div>
          <p class="font-serif text-3xl font-light mb-3">Mioko</p>
          <p class="text-cream-300 text-sm font-light leading-relaxed max-w-xs">
            Handcrafted organic cookies with European soul, made in small batches in Round Rock, Texas.
          </p>
        </div>

        <div class="flex flex-wrap gap-x-12 gap-y-6">
          <div>
            <p class="text-xs tracking-widest uppercase text-earth-400 font-medium mb-4">Sitemap</p>
            <ul class="space-y-2 text-sm font-light text-cream-300">
              <li><a href="#cookies" class="hover:text-cream-50 transition-colors">Cookies</a></li>
              <li><a href="#story" class="hover:text-cream-50 transition-colors">Our Story</a></li>
              <li><a href="#faq" class="hover:text-cream-50 transition-colors">FAQ</a></li>
              <li><a href="#connect" class="hover:text-cream-50 transition-colors">Connect</a></li>
            </ul>
          </div>
          <div>
            <p class="text-xs tracking-widest uppercase text-earth-400 font-medium mb-4">Follow</p>
            <ul class="space-y-2 text-sm font-light text-cream-300">
              <li><a href="https://www.instagram.com/mioko.bakery" target="_blank" class="hover:text-cream-50 transition-colors">Instagram</a></li>
              <li><a href="https://t.me/+gwn4uv3GRi03MThi" target="_blank" class="hover:text-cream-50 transition-colors">Telegram</a></li>
            </ul>
          </div>
        </div>
      </div>

      <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-cream-100/40 text-xs font-light">
          © {new Date().getFullYear()} Mioko Bakery. All rights reserved.
        </p>
        <p class="text-cream-100/30 text-xs font-light text-center">
          Proudly serving the Round Rock community — organic, intentional, local.
        </p>
      </div>

    </div>
  </footer>

</Layout>
